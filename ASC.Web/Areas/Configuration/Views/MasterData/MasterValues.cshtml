@model ASC.Web.Areas.Configuration.Models.MasterValuesViewModel
@{
    ViewData["Title"] = "Master Values Configuration";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row">
        <h4>Quản lý Giá Trị Danh Mục (Master Values)</h4>
        <p class="grey-text">Nhóm: <strong>@Model.MasterDataValueInContext.PartitionKey</strong></p>
        <hr />

        @* Form Thêm Mới *@
        <div class="row">
            <form id="frmMasterValue"
                  asp-action="MasterValues"
                  asp-controller="MasterData"
                  asp-area="Configuration"
                  method="post"
                  class="col s12">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="MasterDataValueInContext.PartitionKey"
                       value="@Model.MasterDataValueInContext.PartitionKey" />

                <div class="row card-panel">
                    <div class="input-field col s4">
                        <input type="text"
                               id="Name"
                               name="MasterDataValueInContext.Name"
                               class="validate" />
                        <label for="Name">Tên giá trị (Ví dụ: Xe máy)</label>
                    </div>

                    <div class="input-field col s4">
                        <input type="text"
                               id="Value"
                               name="MasterDataValueInContext.Value"
                               class="validate" />
                        <label for="Value">Giá trị (Ví dụ: MOTORBIKE)</label>
                    </div>

                    @* THÊM CHECKBOX ISACTIVE *@
                    <div class="input-field col s2" style="margin-top:20px;">
                        <label>
                            <input type="checkbox"
                                   name="MasterDataValueInContext.IsActive"
                                   value="true"
                                   class="filled-in"
                                   checked="checked" />
                            <span>Hoạt động</span>
                        </label>
                    </div>

                    <div class="input-field col s2">
                        <button type="submit"
                                form="frmMasterValue"
                                class="btn waves-effect waves-light green">
                            Thêm Mới <i class="material-icons right">add</i>
                        </button>
                    </div>
                </div>
            </form>
        </div>

        @* Bảng danh sách *@
        <div class="row">
            <table class="highlight centered responsive-table">
                <thead>
                    <tr>
                        <th>Partition Key</th>
                        <th>Tên (Name)</th>
                        <th>Giá trị (Value)</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.MasterDataValues != null && Model.MasterDataValues.Any())
                    {
                        foreach (var item in Model.MasterDataValues)
                        {
                            <tr>
                                <td>@item.PartitionKey</td>
                                <td>@item.Name</td>
                                <td>@item.Value</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="chip green white-text">Đang hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="chip grey white-text">Ngừng hoạt động</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="center-align">Chưa có giá trị nào. Hãy thêm giá trị đầu tiên!</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row">
            <a asp-action="MasterKeys"
               asp-controller="MasterData"
               asp-area="Configuration"
               class="btn waves-effect waves-light grey">
                <i class="material-icons left">arrow_back</i> Quay lại
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('frmMasterValue').addEventListener('submit', function (e) {
            var name = document.getElementById('Name').value.trim();
            var value = document.getElementById('Value').value.trim();
            if (!name || !value) {
                e.preventDefault();
                alert('Vui lòng nhập đầy đủ Tên và Giá trị!');
                return false;
            }
            console.log('Submitting - Name:', name, 'Value:', value);
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
