@model ASC.Web.Areas.Configuration.Models.MasterValuesViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Master Values";
    Layout = "~/Views/Shared/_SecureLayout.cshtml";
}

<div class="row" style="margin-top:20px;">
    <div class="col s12">
        <h4 class="blue-text text-darken-3">
            <i class="fas fa-tags"></i> Giá trị danh mục —
            <span class="blue-text">@Model.MasterDataValueInContext?.PartitionKey</span>
        </h4>
        <a href="/Configuration/MasterData/MasterKeys" class="btn-flat blue-text">
            <i class="fas fa-arrow-left"></i> Quay lại Master Keys
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="row">
        <div class="col s12">
            <div class="card-panel teal lighten-4 teal-text text-darken-3">
                <i class="fas fa-check-circle"></i> @TempData["Success"]
            </div>
        </div>
    </div>
}

<!-- Form thêm giá trị mới -->
<div class="row">
    <div class="col s12">
        <div class="card">
            <div class="card-content">
                <span class="card-title">Thêm giá trị mới</span>
                <form asp-area="Configuration" asp-controller="MasterData"
                      asp-action="MasterValues" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="MasterDataValueInContext.PartitionKey"
                           value="@Model.MasterDataValueInContext?.PartitionKey" />

                    <div class="row">
                        <div class="input-field col s12 m4">
                            <input type="text" id="valName" name="MasterDataValueInContext.Name"
                                   class="validate" required />
                            <label for="valName">Tên hiển thị (VD: Xe máy, Ô tô sedan...)</label>
                        </div>
                        <div class="input-field col s12 m4">
                            <input type="text" id="valValue" name="MasterDataValueInContext.Value"
                                   class="validate" />
                            <label for="valValue">Giá trị mã (VD: MOTORBIKE, SEDAN...)</label>
                        </div>
                        <div class="col s12 m2" style="margin-top:20px;">
                            <label>
                                <input type="checkbox" name="MasterDataValueInContext.IsActive"
                                       value="true" class="filled-in" checked />
                                <span>Kích hoạt</span>
                            </label>
                        </div>
                        <div class="col s12 m2" style="margin-top:15px;">
                            <button type="submit" class="btn waves-effect blue darken-2">
                                <i class="fas fa-plus left"></i> Thêm
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Bảng danh sách -->
<div class="row">
    <div class="col s12">
        <div class="card">
            <div class="card-content">
                <span class="card-title">Danh sách giá trị</span>
                <table class="highlight responsive-table">
                    <thead>
                        <tr>
                            <th>Tên hiển thị</th>
                            <th>Giá trị mã</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.MasterDataValues != null && Model.MasterDataValues.Any())
                        {
                            foreach (var item in Model.MasterDataValues)
                            {
                                <tr>
                                    <td>@item.Name</td>
                                    <td><code>@item.Value</code></td>
                                    <td>
                                        <span class="badge @(item.IsActive ? "green" : "grey") white-text">
                                            @(item.IsActive ? "Hoạt động" : "Ngừng")
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="3" class="center-align grey-text">Chưa có giá trị nào.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
