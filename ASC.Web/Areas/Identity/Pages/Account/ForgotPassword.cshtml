
@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<div class="container">
    <div class="row" style="margin-top: 50px;">
        <div class="col s12 m6 offset-m3">
            <div class="card">
                <div class="card-content">
                    <span class="card-title">Enter your email</span>
                    <p>We will send you a link to reset your password.</p>
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="red-text"></div>
                        <div class="row" style="margin-top: 20px;">
                            <div class="input-field col s12">
                                <input asp-for="Input.Email" class="validate" />
                                <label asp-for="Input.Email">Email Address</label>
                                <span asp-validation-for="Input.Email" class="red-text"></span>
                            </div>
                        </div>
                        <button type="submit" class="btn waves-effect waves-light blue">Send Reset Link</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>