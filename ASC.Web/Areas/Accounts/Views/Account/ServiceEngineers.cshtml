@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model ASC.Web.Areas.Accounts.Models.ServiceEngineerViewModel
@{
    ViewData["Title"] = "Service Engineers";
    Layout = "~/Views/Shared/_SecureLayout.cshtml";
}

<div class="row" style="margin-top:20px;">
    <div class="col s12">
        <h4 class="blue-text text-darken-3">
            <i class="fas fa-user-gear"></i> Quản lý Kỹ sư (Service Engineers)
        </h4>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="row">
        <div class="col s12">
            <div class="card-panel teal lighten-4 teal-text text-darken-3">
                <i class="fas fa-check-circle"></i> @TempData["Success"]
            </div>
        </div>
    </div>
}

<!-- Danh sách kỹ sư -->
<div class="row">
    <div class="col s12">
        <div class="card">
            <div class="card-content">
                <span class="card-title">Danh sách Kỹ sư hiện tại</span>
                <table class="highlight responsive-table">
                    <thead>
                        <tr>
                            <th>Email</th>
                            <th>Tên</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ServiceEngineers != null && Model.ServiceEngineers.Any())
                        {
                            foreach (var user in Model.ServiceEngineers)
                            {
                                <tr>
                                    <td>@user.Email</td>
                                    <td>@(user.FullName ?? user.UserName)</td>
                                    <td>
                                        <span class="badge @(user.IsActive ? "green" : "red") white-text">
                                            @(user.IsActive ? "Hoạt động" : "Bị khóa")
                                        </span>
                                    </td>
                                    <td>
                                        <form asp-area="Accounts" asp-controller="Account"
                                              asp-action="ToggleEngineerStatus" method="post"
                                              style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="email" value="@user.Email" />
                                            <input type="hidden" name="activate" value="@(!user.IsActive)" />
                                            <button type="submit"
                                                    class="btn-small waves-effect @(user.IsActive ? "red" : "green") white-text">
                                                <i class="fas fa-@(user.IsActive ? "lock" : "lock-open")"></i>
                                                @(user.IsActive ? "Khóa" : "Kích hoạt")
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="center-align grey-text">Chưa có kỹ sư nào.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Form thêm kỹ sư mới -->
<div class="row">
    <div class="col s12">
        <div class="card">
            <div class="card-content">
                <span class="card-title">Thêm Kỹ sư mới</span>
                <form asp-area="Accounts" asp-controller="Account"
                      asp-action="ServiceEngineers" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="red-text" style="margin-bottom:10px;"></div>
                    <div class="row">
                        <div class="input-field col s12 m4">
                            <input asp-for="Registration.Email" type="email" class="validate" />
                            <label asp-for="Registration.Email">Email</label>
                            <span asp-validation-for="Registration.Email" class="red-text helper-text"></span>
                        </div>
                        <div class="input-field col s12 m4">
                            <input asp-for="Registration.Password" type="password" class="validate" />
                            <label asp-for="Registration.Password">Mật khẩu</label>
                        </div>
                        <div class="input-field col s12 m4">
                            <input asp-for="Registration.ConfirmPassword" type="password" class="validate" />
                            <label asp-for="Registration.ConfirmPassword">Xác nhận mật khẩu</label>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col s12 right-align">
                            <button type="submit" class="btn waves-effect blue darken-2">
                                <i class="fas fa-user-plus left"></i> Tạo tài khoản
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
