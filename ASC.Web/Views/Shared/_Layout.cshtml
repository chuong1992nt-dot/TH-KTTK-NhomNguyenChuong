@using Microsoft.AspNetCore.Identity
@using ASC.Web.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@using Microsoft.Extensions.Options
@using ASC.Web.Configuration
@inject IOptions<ApplicationSettings> _configurationSettings

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        @ViewData["Title"] - @_configurationSettings.Value.ApplicationTitle
    </title>

    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">
</head>

<body>
    <nav class="blue darken-2">
        <div class="nav-wrapper container">
            <a href="/" class="brand-logo" style="display: flex; align-items: center; height: 100%;">
                <img src="/images/carlogo.png"
                     alt="Logo"
                     width="40"
                     height="40"
                     style="object-fit: contain; margin-right: 10px; flex-shrink: 0;">

                <span class="logo-text" style="font-size: 1.2rem; white-space: nowrap;">
                    @_configurationSettings.Value.ApplicationTitle
                </span>
            </a>

            <a href="#" data-target="mobile-demo" class="sidenav-trigger"><i class="material-icons">menu</i></a>

            <ul class="right hide-on-med-and-down">
                <li><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>

                @if (SignInManager.IsSignedIn(User) && (User.IsInRole("Admin") || User.IsInRole("Engineer")))
                {
                    <li><a asp-area="ServiceRequests" asp-controller="Dashboard" asp-action="Dashboard">Dashboard Quản Trị</a></li>
                }

                <li><a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></li>

                <partial name="_LoginPartial" />
            </ul>
        </div>
    </nav>

    <ul class="sidenav" id="mobile-demo">
        <li><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>

        @if (SignInManager.IsSignedIn(User) && (User.IsInRole("Admin") || User.IsInRole("Engineer")))
        {
            <li><a asp-area="ServiceRequests" asp-controller="Dashboard" asp-action="Dashboard">Dashboard Quản Trị</a></li>
        }

        <li><a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></li>

        <partial name="_LoginPartial" />
    </ul>

    <div class="container" style="margin-top:30px">
        @RenderBody()
    </div>

    <footer class="page-footer blue darken-2">
        <div class="container center">
            © 2026 - @_configurationSettings.Value.ApplicationTitle
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
    <script src="~/js/init.js"></script>

    <script>
        $(document).ready(function(){
            $('.sidenav').sidenav();
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>