@model ASC.Web.Models.NewUserViewModel
@{
    ViewData["Title"] = "Provision User";
    Layout = "_SecureLayout";
}

<div class="row padding-top-20px">
    <div class="col s12 m8 offset-m2">
        <div class="card z-depth-3">
            <div class="card-content">
                <span class="card-title"><h4>Cấp phép tài khoản mới</h4></span>
                <div class="divider"></div>
                <form asp-action="ProvisionUser" method="post" class="padding-top-20px">
                    <div asp-validation-summary="All" class="red-text"></div>

                    <div class="row">
                        <div class="input-field col s12">
                            <i class="material-icons prefix">email</i>
                            <input asp-for="Email" class="validate" />
                            <label asp-for="Email">Địa chỉ Email</label>
                        </div>
                    </div>

                    <div class="row">
                        <div class="input-field col s12">
                            <i class="material-icons prefix">lock</i>
                            <input asp-for="Password" class="validate" type="password" />
                            <label asp-for="Password">Mật khẩu</label>
                        </div>
                    </div>

                    <div class="row">
                        <div class="input-field col s12">
                            <i class="material-icons prefix">assignment_ind</i>
                            <select asp-for="Role" class="browser-default" style="margin-left: 3rem; width: calc(100% - 3rem);">
                                <option value="" disabled selected>-- Chọn quyền hạn --</option>
                                @if (ViewBag.Roles != null)
                                {
                                    foreach (var role in ViewBag.Roles)
                                    {
                                        <option value="@role">@role</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row center-align margin-top-20px">
                        <button type="submit" class="btn waves-effect waves-light blue">
                            Tạo tài khoản
                            <i class="material-icons right">send</i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>