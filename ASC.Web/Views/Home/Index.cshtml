@{
    ViewData["Title"] = "Home";
}

<div class="center">

    <h3>
        Welcome to Automobile Service Center
    </h3>

    <p>
        This is a demo ASP.NET Core MVC application using Materialize CSS.
    </p>

</div>

<br />

<div class="row">

    <!-- Service Card -->

    <div class="col s12 m4">

        <div class="card">

            <div class="card-content">

                <span class="card-title">
                    Car Maintenance
                </span>

                <p>
                    Professional maintenance services for your vehicle.
                </p>

            </div>

        </div>

    </div>

    <!-- Repair Card -->

    <div class="col s12 m4">

        <div class="card">

            <div class="card-content">

                <span class="card-title">
                    Repair Services
                </span>

                <p>
                    Experienced mechanics ready to repair any issue.
                </p>

            </div>

        </div>

    </div>

    <!-- Support Card -->

    <div class="col s12 m4">

        <div class="card">

            <div class="card-content">

                <span class="card-title">
                    Customer Support
                </span>

                <p>
                    24/7 support for all customers.
                </p>

            </div>

        </div>

    </div>

</div>

<div class="center">

    <a class="waves-effect waves-light btn blue">
        Get Started
    </a>

</div>