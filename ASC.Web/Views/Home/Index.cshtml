@{
    ViewData["Title"] = "Home";
}

<div id="index-banner" class="parallax-container" style="height: 400px">
    <div class="section no-pad-bot valign-wrapper" style="width: 100%; height: 100%;">
        <div class="container">
            <h1 class="header center white-text">Automobile Service Center</h1>
            <div class="row center">
                <h5 class="header col s12 light white-text">This is a demo ASP.NET Core MVC application using Materialize CSS.</h5>
            </div>
            <div class="row center" style="margin-top: 30px;">
                <a class="btn-large waves-effect waves-light blue">Get Started</a>
            </div>
        </div>
    </div>
    <div class="parallax">
        <img src="/images/background1.png" alt="Background 1">
    </div>
</div>

<div class="container">
    <div class="section">
        <div class="row">
            <div class="col s12 m4">
                <div class="card">
                    <div class="card-content">
                        <span class="card-title">Car Maintenance</span>
                        <p>Professional maintenance services for your vehicle.</p>
                    </div>
                </div>
            </div>
            <div class="col s12 m4">
                <div class="card">
                    <div class="card-content">
                        <span class="card-title">Repair Services</span>
                        <p>Experienced mechanics ready to repair any issue.</p>
                    </div>
                </div>
            </div>
            <div class="col s12 m4">
                <div class="card">
                    <div class="card-content">
                        <span class="card-title">Customer Support</span>
                        <p>24/7 support for all customers.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="parallax-container valign-wrapper">
    <div class="section no-pad-bot" style="width: 100%">
        <div class="container">
            <div class="row center">
                <h5 class="header col s12 light white-text">Chúng tôi luôn đồng hành cùng chuyến đi của bạn.</h5>
            </div>
        </div>
    </div>
    <div class="parallax">
        <img src="~/images/background2.jpg" alt="Background 2 ">
    </div>
</div>