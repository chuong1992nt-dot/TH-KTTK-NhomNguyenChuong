@{
    ViewData["Title"] = "Dashboard";
    Layout = "_SecureLayout";
}

<div class="section">
    <h3 class="blue-text">Hệ thống quản trị</h3>
    <div class="row">
        <div class="col s12 m4">
            <div class="card blue white-text">
                <div class="card-content">
                    <span class="card-title">Total Customers</span>
                    <h4>120</h4>
                </div>
            </div>
        </div>
        <div class="col s12 m4">
            <div class="card green white-text">
                <div class="card-content">
                    <span class="card-title">Total Vehicles</span>
                    <h4>85</h4>
                </div>
            </div>
        </div>
        <div class="col s12 m4">
            <div class="card orange white-text">
                <div class="card-content">
                    <span class="card-title">Service Orders</span>
                    <h4>42</h4>
                </div>
            </div>
        </div>
    </div>
</div>